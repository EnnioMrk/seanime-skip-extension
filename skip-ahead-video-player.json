{
  "id": "skip-ahead-video-player",
  "name": "Skip Ahead Video Player Button",
  "version": "1.0.0",
  "manifestURI": "https://raw.githubusercontent.com/EnnioMrk/seanime-skip-extension/refs/heads/main/skip-ahead-video-player.json",
  "language": "typescript",
  "type": "plugin",
  "description": "Adds a skip-ahead button next to the video timestamp. Useful for skipping intros or recaps in anime episodes.",
  "author": "Ennio",
  "icon": "",
  "website": "",
  "readme": "",
  "notes": "",
  "lang": "multi",
  "payload": "",
  "payloadURI": "https://raw.githubusercontent.com/EnnioMrk/seanime-skip-extension/refs/heads/main/skip-ahead-video-player.ts",
  "userConfig": {
    "version": 1,
    "requiresConfig": false,
    "fields": [
      {
        "type": "text",
        "name": "skipSeconds",
        "label": "Skip Ahead Seconds",
        "default": "85"
      }
    ]
  },
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": [
        "playback"
      ]
    }
  }
}
